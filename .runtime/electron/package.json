{
  "name": "museon",
  "version": "1.1.0",
  "description": "MUSEON Dashboard - Real-time monitoring and control",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "prebuild": "bash scripts/generate-icon.sh",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "museon",
    "dashboard",
    "monitoring",
    "ai-organism"
  ],
  "author": "MUSEON Team",
  "license": "MIT",
  "dependencies": {
    "chart.js": "^4.4.1",
    "pixi.js": "^7.4.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "electron": "^28.1.4",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.museon.app",
    "productName": "MUSEON",
    "files": [
      "**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "../.runtime-bundle",
        "to": "runtime-bundle",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": {
        "target": "dmg",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "identity": "-",
      "signIgnore": ".*",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": null,
      "entitlementsInherit": null
    },
    "dmg": {
      "sign": false,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  }
}
