# MUSEON 環境設定
# 複製此檔案為 .env，然後填入你的 API Key
#   cp .env.example .env

# Telegram Bot Token (從 @BotFather 取得)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Anthropic API Key (從 console.anthropic.com 取得)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 安裝完成標記（安裝程式會自動設定）
MUSEON_SETUP_DONE=0

# 每日 Token 上限
MUSEON_DAILY_TOKEN_LIMIT=2000000

# Dify 工作流引擎（選用）
# 自架 Dify: docker compose up -d（預設 localhost:5001）
# API Key 從 Dify Dashboard → Settings → API Key 取得
DIFY_BASE_URL=http://localhost:5001
DIFY_API_KEY=
