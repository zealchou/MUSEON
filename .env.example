# MUSEON 環境設定
# 複製此檔案為 .env，然後填入你的 API Key
#   cp .env.example .env
#
# ⚠️  重要：請務必將 placeholder 值替換為真實 API Key！
#     PreflightGate 會在啟動前驗證所有 Key，
#     若偵測到 placeholder（如 "your-xxx-here"）將阻止啟動。

# ─── 必要 API Key ───────────────────────────────

# Anthropic API Key (從 console.anthropic.com 取得)
# 前綴格式：sk-ant-...
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── 選用 API Key ───────────────────────────────

# Telegram Bot Token (從 @BotFather 取得)
# 留空 = 不啟用 Telegram 功能
TELEGRAM_BOT_TOKEN=

# Telegram 擁有者 ID（用於權限控制）
TELEGRAM_OWNER_ID=
# Telegram 信任 ID 清單（逗號分隔）
TELEGRAM_TRUSTED_IDS=

# Dify 工作流引擎（選用）
# 自架 Dify: docker compose up -d（預設 localhost:5001）
# API Key 從 Dify Dashboard → Settings → API Key 取得
DIFY_BASE_URL=http://localhost:5001
DIFY_API_KEY=

# ─── 社群頻道 API Key（選用）────────────────────

# Instagram Access Token
INSTAGRAM_ACCESS_TOKEN=
# LINE Channel
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Google Drive 憑證路徑
GOOGLE_DRIVE_CREDENTIALS=

# ─── 外部工具服務 ─────────────────────────────────

# SearXNG 搜尋引擎（Docker 自架）
SEARXNG_URL=http://localhost:8888
# Firecrawl 網頁爬取（Docker 自架）
FIRECRAWL_URL=http://localhost:3002
# PaddleOCR 文字辨識（Docker 自架）
PADDLEOCR_URL=http://localhost:8866
# Stability AI 圖片生成
STABILITY_API_KEY=
# Qdrant 向量資料庫
QDRANT_URL=http://localhost:6333

# ─── Zotero 文獻管理（選用）───────────────────────

ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=

# ─── GitHub / Federation（選用）───────────────────

GITHUB_TOKEN=          # Personal Access Token，需要 gist 權限（每日晨報上傳用）
GITHUB_USER=           # 你的 GitHub 用戶名（可選，預設 MUSEON-bot）
MUSEON_WIKI_REPO=

# ─── Email 設定（選用）────────────────────────────

MUSEON_IMAP_HOST=
MUSEON_IMAP_PORT=993
MUSEON_SMTP_HOST=
MUSEON_SMTP_PORT=587
MUSEON_EMAIL_USER=
MUSEON_EMAIL_PASS=

# ─── 系統設定 ───────────────────────────────────

# 安裝完成標記（安裝程式會自動設定，請勿手動修改）
MUSEON_SETUP_DONE=0

# 每日 Token 上限
MUSEON_DAILY_TOKEN_LIMIT=2000000

# 工作空間路徑（預設 ~/MUSEON）
MUSEON_WORKSPACE=

# MUSEON 主目錄（預設 ~/MUSEON）
MUSEON_HOME=

# ─── Federation 設定（選用）───────────────────────

MUSEON_NODE_ID=
MUSEON_FEDERATION_MODE=
MUSEON_FEDERATION_REPO=
MUSEON_ORIGIN_URL=
